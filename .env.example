# Copy to .env in this directory and/or api/.env as needed.
OPENAI_API_KEY=your_key_here
FINNHUB_API_KEY=your_finnhub_api_key_here

# Persistence: the `api` service stores SQLite on Docker volume `finance_api_data`
# (see docker-compose.yml: SQLITE_PATH=/app/data/demo.db). Transactions page uploads
# and Command Center wealth edits all write to that file; they survive `docker compose stop`.
# `docker compose down -v` removes named volumes and will delete that database.
