# Copy to .env and set your keys.
# OpenAI: used for CSV transaction categorization (gpt-4o-mini).
OPENAI_API_KEY=your_key_here

# Finnhub: live quotes on Market Watch and Command Center ticker (`GET /api/market/quotes`).
# Get a key at https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here

# Optional: SQLite file path. In Docker Compose this is set to /app/data/demo.db
# on the named volume `finance_api_data` so ledger + wealth data persist across
# container restarts (same DB for CSV uploads, transaction deletes, sub-account edits).
# SQLITE_PATH=./data/demo.db
